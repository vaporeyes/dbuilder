<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DBuilder.Editor"
        x:Class="DBuilder.Editor.MainWindow"
        Width="1100" Height="800"
        Title="DBuilder">

    <!-- Explicit Grid rows (not DockPanel) so the GL map view is confined to its own row and
         can never overlap / steal pointer input from the menu and toolbar. -->
    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- Menu bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New Map" Click="OnNewMap" />
                <MenuItem Header="_Open WAD..." Click="OnOpen" />
                <MenuItem Header="Open _Recent" x:Name="OpenRecentMenu" />
                <MenuItem Header="Open _Map..." Click="OnOpenMap" />
                <MenuItem Header="Add _Resource (IWAD/PK3)..." Click="OnAddResource" />
                <MenuItem Header="_Save WAD As..." Click="OnSave" />
                <MenuItem Header="Save As _Format..." Click="OnSaveAsFormat" />
                <Separator />
                <MenuItem Header="Load _Game Config..." Click="OnLoadConfig" />
                <MenuItem Header="Map _Options..." Click="OnMapOptions" />
                <MenuItem Header="_Settings..." Click="OnSettings" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Click="OnUndo" />
                <MenuItem Header="_Redo" Click="OnRedo" />
                <Separator />
                <MenuItem Header="Cu_t" Click="OnCut" />
                <MenuItem Header="_Copy" Click="OnCopy" />
                <MenuItem Header="_Paste" Click="OnPaste" />
                <MenuItem Header="D_uplicate" Click="OnDuplicate" />
                <Separator />
                <MenuItem Header="_Delete selection" Click="OnDelete" />
                <MenuItem Header="Select _all" Click="OnSelectAll" />
                <MenuItem Header="_Invert selection" Click="OnInvertSelection" />
                <MenuItem Header="Select _none" Click="OnSelectNone" />
                <MenuItem Header="Selection _Groups" x:Name="SelectionGroupsMenu" />
                <Separator />
                <MenuItem Header="Stitch _geometry" Click="OnStitch" />
                <MenuItem Header="_Join sectors" Click="OnJoinSectors" />
                <MenuItem Header="Mer_ge sectors" Click="OnMergeSectors" />
                <MenuItem Header="_Transform selection">
                    <MenuItem Header="Flip _Horizontal" Click="OnFlipH" />
                    <MenuItem Header="Flip _Vertical" Click="OnFlipV" />
                    <MenuItem Header="Rotate 90 C_W" Click="OnRotateCW" />
                    <MenuItem Header="Rotate 90 CC_W" Click="OnRotateCCW" />
                    <MenuItem Header="Scale _Up" Click="OnScaleUp" />
                    <MenuItem Header="Scale _Down" Click="OnScaleDown" />
                </MenuItem>
                <MenuItem Header="_Align textures">
                    <MenuItem Header="Align _Horizontal" Click="OnAlignTexturesX" />
                    <MenuItem Header="Align _Vertical" Click="OnAlignTexturesY" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Save _Prefab..." Click="OnSavePrefab" />
                <MenuItem Header="_Insert Prefab..." Click="OnInsertPrefab" />
                <Separator />
                <MenuItem Header="_Find &amp; Replace..." Click="OnFindReplace" />
                <MenuItem Header="_Flags..." Click="OnFlags" />
                <MenuItem Header="_Custom Fields..." Click="OnCustomFields" />
                <MenuItem Header="Ta_gs..." Click="OnTagList" />
                <MenuItem Header="_Insert at Cursor" Click="OnInsertAtCursor" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Edit Mode">
                    <MenuItem Header="_Vertices" Click="OnModeVertices" />
                    <MenuItem Header="_Linedefs" Click="OnModeLinedefs" />
                    <MenuItem Header="_Sectors" Click="OnModeSectors" />
                    <MenuItem Header="_Things" Click="OnModeThings" />
                </MenuItem>
                <MenuItem Header="_Fit to map" Click="OnFit" />
                <MenuItem Header="_Go To Coordinates..." Click="OnGoToCoordinates" />
                <MenuItem Header="View Used _Tags..." Click="OnTagStatistics" />
                <MenuItem Header="View Thing _Types..." Click="OnThingStatistics" />
                <MenuItem Header="_Browsers">
                    <MenuItem Header="_Textures..." Click="OnBrowseWallTextures" />
                    <MenuItem Header="_Flats..." Click="OnBrowseFlats" />
                    <MenuItem Header="_Things..." Click="OnBrowseThingsCatalog" />
                    <MenuItem Header="_Linedef Actions..." Click="OnBrowseActionsCatalog" />
                    <MenuItem Header="_Sector Effects..." Click="OnBrowseEffectsCatalog" />
                </MenuItem>
                <MenuItem Header="Toggle _3D Mode" Click="OnToggle3DMode" />
                <MenuItem Header="Show Sector _Fills" Click="OnToggleSectorFills" />
                <MenuItem Header="Show _Things" Click="OnToggleThings" />
                <MenuItem Header="Things as _arrows" Click="OnToggleThingArrows" />
                <MenuItem Header="Show _3D Floors" Click="OnToggle3DFloors" />
                <MenuItem Header="Thing _Filter..." Click="OnThingFilter" />
                <MenuItem Header="_Grid Setup..." Click="OnGridSetup" />
                <MenuItem Header="_Snap to Grid" Click="OnToggleSnapToGrid" />
                <MenuItem Header="Grid Size _Down" Click="OnGridSizeDown" />
                <MenuItem Header="Grid Size _Up" Click="OnGridSizeUp" />
                <MenuItem Header="Show _Blockmap" Click="OnToggleBlockmap" />
                <MenuItem Header="Show _Nodes" Click="OnToggleNodes" />
            </MenuItem>
            <MenuItem Header="_Draw">
                <MenuItem Header="_Make Sector at Cursor" Click="OnMakeSectorAtCursor" />
                <MenuItem Header="Draw _Sector" Click="OnDrawSector" />
                <MenuItem Header="Draw _Lines Only" Click="OnDrawLines" />
                <MenuItem Header="Draw _Curve" Click="OnDrawCurve" />
                <MenuItem Header="Draw _Rectangle" Click="OnDrawRectangle" />
                <MenuItem Header="Draw _Ellipse" Click="OnDrawEllipse" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Check Map" Click="OnCheckMap" />
                <MenuItem Header="_Clean Up Geometry" Click="OnCleanUpGeometry" />
                <MenuItem Header="_Test Map" Click="OnTestMap" />
                <MenuItem Header="Sound _Propagation" Click="OnSoundPropagation" />
                <MenuItem Header="Build _Stairs..." Click="OnBuildStairs" />
                <MenuItem Header="Apply S_lopes (specials)" Click="OnApplySlopes" />
                <MenuItem Header="Re_ject Viewer" Click="OnRejectViewer" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Shortcuts..." Click="OnShortcuts" />
                <MenuItem Header="_About" Click="OnAbout" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#202530" Padding="4" BorderBrush="#10000000" BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="Open" Click="OnOpen" />
                    <Button Content="Map" Click="OnOpenMap" />
                    <Button Content="Save" Click="OnSave" />
                    <Button Content="Undo" Click="OnUndo" />
                    <Button Content="Redo" Click="OnRedo" />
                    <Button Content="Delete" Click="OnDelete" />
                    <Button Content="Fit" Click="OnFit" />
                    <Button Content="3D" Click="OnToggle3DMode" />
                    <Button Content="Vtx" Click="OnModeVertices" />
                    <Button Content="Line" Click="OnModeLinedefs" />
                    <Button Content="Sec" Click="OnModeSectors" />
                    <Button Content="Thing" Click="OnModeThings" />
                    <Button Content="Make" Click="OnMakeSectorAtCursor" />
                    <Button Content="Draw" Click="OnDrawSector" />
                    <Button Content="Lines" Click="OnDrawLines" />
                    <Button Content="Curve" Click="OnDrawCurve" />
                    <Button Content="Rect" Click="OnDrawRectangle" />
                    <Button Content="Ellipse" Click="OnDrawEllipse" />
                    <Button Content="Check" Click="OnCheckMap" />
                    <Button Content="Clean" Click="OnCleanUpGeometry" />
                    <Button Content="Test" Click="OnTestMap" />
                    <Button Content="Stairs" Click="OnBuildStairs" />
                    <Button Content="Slopes" Click="OnApplySlopes" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Central map view -->
        <local:MapControl Grid.Row="2" x:Name="MapView" />

        <!-- Info panel: text on the left, texture/sprite previews on the right -->
        <Border Grid.Row="3" Background="#1c2028" Padding="8,6" Height="124"
                BorderBrush="#10000000" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <Panel Grid.Column="0">
                    <!-- Free-text help / multi-selection summary (shown when no single element is selected). -->
                    <TextBlock x:Name="InfoText" Foreground="#a0a8b0" TextWrapping="Wrap"
                               VerticalAlignment="Top"
                               Text="No map loaded. File &gt; Open WAD to begin." />
                    <!-- Structured label/value fields for a single selected thing/linedef/sector. -->
                    <StackPanel x:Name="InfoFields" IsVisible="False" Orientation="Vertical" Spacing="2" />
                </Panel>
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="PreviewPanel" Orientation="Horizontal" Spacing="10" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="#181c24" Padding="6,3">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" x:Name="StatusText" Text="Ready" Foreground="#c0c8d0" />
                <TextBlock Grid.Column="1" x:Name="ModeText" Text="Mode: -" Foreground="#c0c8d0" Margin="12,0,0,0" />
                <TextBlock Grid.Column="2" x:Name="GridText" Text="Grid: -" Foreground="#c0c8d0" Margin="12,0,0,0" />
                <TextBlock Grid.Column="3" x:Name="CoordText" Text="" Foreground="#c0c8d0" Margin="12,0,0,0" />
            </Grid>
        </Border>

    </Grid>
</Window>
